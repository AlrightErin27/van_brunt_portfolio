---
import "./Home.css";
import Navbar from "./Navbar/Navbar.astro";
---

<Navbar />

<div class="home-background">
  <main class="home-main">
    <section class="home-panel home-panel-title">
      <h1>I'm Erin.</h1>
    </section>

    <section class="home-panel home-panel-about">
      <div class="home-about-heading">
        <h2>About Me</h2>
      </div>

      <div class="home-about-copy">
        <p>
          I'm a software engineer transitioning into digital accessibility.
          I'm currently building my skills in accessibility testing, WCAG,
          assistive technology, and inclusive web development.
        </p>
      </div>

      <div class="home-about-media">
        <figure class="home-media-block">
          <div class="home-image-placeholder">
            Graphic goes here
          </div>

          <figcaption>
            A short caption or statement can go here.
          </figcaption>
        </figure>

        <figure class="home-media-block">
          <div class="home-image-placeholder">
            Photo goes here
          </div>

          <figcaption>
            Erin Van Brunt
          </figcaption>
        </figure>
      </div>
    </section>

    <section class="home-panel home-panel-details">
      <p>
        This area can hold a few short points about my accessibility work,
        software background, and current focus.
      </p>
    </section>
  </main>
</div>