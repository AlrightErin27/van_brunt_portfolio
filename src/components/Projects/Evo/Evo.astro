---
import "./Evo.css";

/*
	TODO: Import these components after their files exist.

	import Monitor from "./Monitor.astro";
	import Terminal from "./Terminal.astro";
	import SidePanel from "./SidePanel.astro";

	Evo.astro should remain responsible for:
	- The page introduction
	- The overall console layout
	- The primary heading hierarchy

	The imported components should manage their own:
	- Internal markup
	- Interactive behavior
	- Component-specific accessibility
	- Component-specific CSS
*/
---

<main
	id="main-content"
	class="evo"
	tabindex="-1"
>
	<div class="evo__inner">
		<header class="evo__intro">
			<div class="evo__intro-heading">
				<p class="evo__eyebrow">
					Interactive project
				</p>

				<h1 class="evo__title">
					Evo
				</h1>
			</div>

			<div class="evo__summary">
				<div
					class="evo__accent-line"
					aria-hidden="true"
				></div>

				<p class="evo__description">
					Hatch a conversational creature that
					evolves through your answers.
				</p>

				<p class="evo__supporting-text">
					Evo is an accessibility-first,
					session-based AI pet powered by Google
					Gemini. Through conversation, your
					answers shape its personality, behavior,
					and appearance—showcasing practical AI
					integration and accessible interaction
					design.
				</p>
			</div>
		</header>

		<section
			class="evo-console"
			aria-labelledby="evo-console-title"
		>
			<header class="evo-console__header">
				<div>
					<p class="evo-console__eyebrow">
						Evo creature system
					</p>

					<!--
						The section needs a real heading for screen-reader
						navigation, even though the visual design does not
						currently need another visible heading.
					-->
					<h2
						id="evo-console-title"
						class="evo-console__title visually-hidden"
					>
						Evo creature console
					</h2>
				</div>

				<!--
					TODO: Update this text as the game state changes.

					Suggested states:
					- Ready
					- Session active
					- Thinking
					- Updating creature
					- Connection error

					Keep status messages brief. Because this element uses
					role="status", updates will be announced politely by
					screen readers without interrupting other content.
				-->
				<p
					class="evo-console__status"
					role="status"
					aria-live="polite"
					aria-atomic="true"
				>
					<span
						class="evo-console__status-indicator"
						aria-hidden="true"
					></span>

					Ready
				</p>
			</header>

			<div class="evo-console__layout">
				<div class="evo-console__primary">
					<div class="evo-console__slot">
						<!--
							TODO: Replace this entire placeholder section
							with the Monitor component:

							<Monitor />

							The completed Monitor component should:
							- Render the 50 × 30 SVG grid
							- Give the SVG role="img"
							- Include an accessible title and description
							- Update the description when the pet changes
							- Avoid announcing purely decorative animation
							- Respect prefers-reduced-motion
						-->

						<section
							class="evo-placeholder evo-placeholder--monitor"
							aria-labelledby="evo-monitor-title"
						>
							<div class="evo-placeholder__header">
								<h3
									id="evo-monitor-title"
									class="evo-placeholder__title"
								>
									Evolution display
								</h3>

					
							</div>

							<div class="evo-monitor-preview">
								<div class="evo-placeholder__message">
									<p class="evo-placeholder__component-name">
										Monitor component
									</p>

									<p>
										The egg and evolving creature
										will appear here.
									</p>
								</div>
							</div>
						</section>
					</div>

					<div class="evo-console__slot">
						<!--
							TODO: Replace this entire placeholder section
							with the Terminal component:

							<Terminal />

							The completed Terminal component should:
							- Use a properly associated label for every field
							- Keep instructions outside placeholder text
							- Use a role="log" region for conversation history
							- Announce new messages politely
							- Preserve messages visually for review
							- Move focus only when the user expects it
							- Expose loading and error states in text
							- Prevent duplicate submissions while Gemini responds
							- Include an accessible name for the submit control
						-->

						<section
							class="evo-placeholder evo-placeholder--terminal"
							aria-labelledby="evo-terminal-title"
						>
							<div class="evo-placeholder__header">
								<h3
									id="evo-terminal-title"
									class="evo-placeholder__title"
								>
									Dialogue terminal
								</h3>

								<p class="evo-placeholder__meta">
									Session inactive
								</p>
							</div>

							<div class="evo-terminal-preview">
								<p class="evo-terminal-preview__prompt">
									<span aria-hidden="true">
										&gt;
									</span>

									Terminal component
								</p>

								<p>
									The pet-name field, conversation
									history, questions, and answer
									controls will live here.
								</p>
							</div>
						</section>
					</div>
				</div>

				<div class="evo-console__slot evo-console__slot--side">
					<!--
						TODO: Replace this entire placeholder aside
						with the SidePanel component:

						<SidePanel />

						The completed SidePanel component should:
						- Keep Start over disabled until a session begins
						- Keep How to play available before gameplay
						- Keep Accessibility settings available before gameplay
						- Confirm before erasing an active session
						- Use native <dialog> elements for modal content
						  when browser support and implementation allow
						- Return focus to the control that opened a dialog
						- Avoid using color alone to communicate a setting
					-->

					<aside
						class="evo-placeholder evo-side-panel"
						aria-labelledby="evo-controls-title"
					>
						<div class="evo-side-panel__heading">
							<p class="evo-side-panel__eyebrow">
								Console panel
							</p>

							<h3
								id="evo-controls-title"
								class="evo-side-panel__title"
							>
								System controls
							</h3>
						</div>

						<div class="evo-side-panel__controls">
							<!--
								TODO: Enable only when there is an active
								session to reset.
							-->
							<button
								class="evo-control"
								type="button"
								disabled
							>
								<span
									class="evo-control__number"
									aria-hidden="true"
								>
									01
								</span>

								<span>
									Start over
								</span>
							</button>

							<!--
								TODO: This control should eventually remain
								available before and during gameplay.

								If it opens a dialog, the dialog should have
								a visible heading and a clear Close button.
							-->
							<button
								class="evo-control"
								type="button"
								disabled
							>
								<span
									class="evo-control__number"
									aria-hidden="true"
								>
									02
								</span>

								<span>
									How to play
								</span>
							</button>

							<!--
								TODO: This control should eventually remain
								available before and during gameplay.

								Potential settings may include:
								- Reduced or no animation
								- Simplified visual effects
								- Terminal announcement preferences
								- Alternate pet descriptions
							-->
							<button
								class="evo-control"
								type="button"
								disabled
							>
								<span
									class="evo-control__number"
									aria-hidden="true"
								>
									03
								</span>

								<span>
									Accessibility settings
								</span>
							</button>
						</div>

						<p class="evo-side-panel__note">
							Game controls will become available
							as the interactive systems are
							connected.
						</p>
					</aside>
				</div>
			</div>
		</section>
	</div>
</main>