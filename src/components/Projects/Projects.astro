---
import "./Projects.css";

type Project = {
	title: string;
	label: string;
	description: string;
	href: string;
	status: "available" | "coming-soon";
};

const projects: Project[] = [
	{
		title: "Evo",
		label: "Featured project",
		description:
			"An accessible virtual pet experience built around a terminal-style interface and an evolving pixel creature.",
		href: "/projects/evo",
		status: "available",
	},
	{
		title: "Coming Soon",
		label: "Future project",
		description:
			"Lorem ipsum dolor sit amet, consectetur adipiscing elit. Pellentesque eget lacus vitae neque maximus pellentesque. Nam commodo ut orci nec lacinia. Maecenas blandit tempor eleifend. Nullam hendrerit nibh et velit vestibulum pulvinar.",
		href: "/projects/quiet-signal",
		status: "coming-soon",
	},
	{
		title: "Coming Soon",
		label: "Future project",
		description:
			"Etiam condimentum, nisl id pellentesque sollicitudin, justo justo facilisis est, tempor aliquet sem nulla sit amet sem. Nullam congue, turpis eget auctor tempus, diam dui pretium dui, at scelerisque dolor nisi ultrices lorem.",
		href: "/projects/open-form",
		status: "coming-soon",
	},
];
---

<main
	id="main-content"
	tabindex="-1"
	class="projects-page"
>
	<div class="projects-page__inner">
		<header class="projects-page__intro">
			<div>
				<p class="projects-page__eyebrow">
					Selected work
				</p>

				<h1 class="projects-page__title">
					Projects built
					with access
					in mind.
				</h1>
			</div>

			<div class="projects-page__summary">
				<div
					class="projects-page__accent-line"
					aria-hidden="true"
				></div>

				<p>
					A growing collection of projects,
					experiments, and case studies that
					bring accessibility, engineering, and
					visual design together.
				</p>

				<p>
					Each completed project will include
					the problem, my process, accessibility
					decisions, and what I learned.
				</p>
			</div>
		</header>

		<section
			class="projects-collection"
			aria-labelledby="project-list-title"
		>
			<div class="projects-collection__heading">
				<h2 id="project-list-title">
					Selected projects
				</h2>
			</div>

			<ul class="projects-grid">
				{
					projects.map((project, index) => {
						const projectNumber = String(
							index + 1,
						).padStart(2, "0");

						const titleId =
							`project-${index + 1}-title`;

						const linkLabelId =
							`project-${index + 1}-link-label`;

						return (
							<li class="project-card">
								<article
									class="project-card__article"
									aria-labelledby={titleId}
								>
									<a
										class="project-card__surface project-card__surface--link"
										href={project.href}
										aria-labelledby={`${linkLabelId} ${titleId}`}
									>
										<span
											id={linkLabelId}
											class="visually-hidden"
										>
											View project:
										</span>

										<div
											class="project-card__visual"
											aria-hidden="true"
										>
											<span class="project-card__number">
												{projectNumber}
											</span>
										</div>

										<div class="project-card__body">
											<p class="project-card__label">
												{project.label}
											</p>

											<h3
												id={titleId}
												class="project-card__title"
											>
												{project.title}
											</h3>

											<p class="project-card__description">
												{project.description}
											</p>

											<div class="project-card__action">
												<p
													class:list={[
														project.status ===
														"available"
															? "project-card__cta"
															: "project-card__coming-soon",
													]}
													aria-hidden="true"
												>
													<span>
														{
															project.status ===
															"available"
																? "View project"
																: "Project coming soon"
														}
													</span>

													<span class="project-card__arrow">
														→
													</span>
												</p>
											</div>
										</div>
									</a>
								</article>
							</li>
						);
					})
				}
			</ul>
		</section>
	</div>
</main>